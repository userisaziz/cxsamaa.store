# ===========================================
# SAMAA Environment Variables
# Copy this file to .env and fill in the values
# ===========================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://samaa:samaa_dev_password@localhost:5432/samaa
DATABASE_URL_SYNC=postgresql://samaa:samaa_dev_password@localhost:5432/samaa

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Authentication ---
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- File Storage ---
# Options: local, r2
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=./uploads

# --- Cloudflare R2 (when STORAGE_BACKEND=r2) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=samaa-audio
# R2_PUBLIC_URL=  # Set if bucket has public access enabled (e.g., https://pub-xxx.r2.dev)

# --- NVIDIA NIM API ---
NVIDIA_API_KEY=
NVIDIA_STT_MODEL=parakeet-rnnt-1.1b
NVIDIA_DIARIZATION_MODEL=streusand-rnnt
NVIDIA_LLM_MODEL=meta/llama-3.3-70b-instruct

# --- Pyannote.audio (Local Diarization) ---
# Get token from: https://hf.co/settings/tokens
# Pyannote provides superior diarization accuracy vs cloud APIs
DIARIZATION_USE_PYANNOTE=true
PYANNOTE_HF_TOKEN=
PYANNOTE_MODEL_NAME=pyannote/speaker-diarization-3.1
# PYANNOTE_DEVICE=  # 'cpu', 'cuda', 'mps' (leave empty for auto-detect)

# --- Silero VAD (Voice Activity Detection) ---
# Detects speech regions to remove silence and reduce processing costs
VAD_USE_SILERO=true
VAD_THRESHOLD=0.5  # Speech probability threshold (0.0-1.0)
VAD_MIN_SPEECH_DURATION_MS=250  # Minimum speech segment duration
VAD_MIN_SILENCE_DURATION_MS=500  # Minimum silence to mark boundary

# --- Audio Chunking for Long Recordings ---
# Process long audio in chunks with overlap to maintain context
AUDIO_CHUNK_DURATION_MINUTES=15  # 15-minute chunks
AUDIO_CHUNK_OVERLAP_SECONDS=30  # 30-second overlap between chunks

# --- NVIDIA Sortformer Diarization (Future) ---
# Placeholder for future Sortformer integration (not yet available from NVIDIA)
DIARIZATION_USE_SORTFORMER=false
# SORTFORMER_ENDPOINT=  # Set when NVIDIA provides endpoint
# SORTFORMER_MODEL=nvidia/sortformer-diarization-1.0

# --- Conversation Turn Builder ---
# Merges word-level transcripts into speaker turns
TURN_GAP_THRESHOLD=1.0  # Max seconds between words to continue turn

# --- Role Classification ---
# Classifies speakers as Salesperson or Customer
ROLE_CLASSIFICATION_METHOD=LLM  # LLM or Heuristic (LLM tries first, falls back to Heuristic)
ROLE_CLASSIFICATION_CONFIDENCE_THRESHOLD=0.7  # Min confidence to trust LLM result

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- CORS ---
CORS_ORIGINS=http://localhost:3000
