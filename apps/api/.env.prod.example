# Production environment configuration for Cloud Run
# Copy this file to .env.prod and fill in the values

# Database (Cloud SQL)
DATABASE_URL=postgresql+asyncpg://samaa:YOUR_PASSWORD@/samaa?host=/cloudsql/YOUR_PROJECT:us-central1:samaa-db
DATABASE_URL_SYNC=postgresql://samaa:YOUR_PASSWORD@/samaa?host=/cloudsql/YOUR_PROJECT:us-central1:samaa-db

# Redis (Upstash or managed Redis)
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_REDIS.upstash.io:6379

# JWT
JWT_SECRET=YOUR_RANDOM_SECRET_HERE
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Storage (Cloudflare R2)
STORAGE_BACKEND=r2
R2_ACCOUNT_ID=YOUR_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY
R2_BUCKET=samaa-audio
R2_PUBLIC_URL=https://your-bucket.your-account.r2.cloudflarestorage.com

# NVIDIA NIM
NVIDIA_API_KEY=YOUR_NVIDIA_API_KEY
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_STT_MODEL=nvidia/parakeet-ctc-1.1b
NVIDIA_DIARIZATION_MODEL=nvidia/streusand-rnnt
NVIDIA_LLM_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_EMBEDDING_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2
NVIDIA_TIMEOUT=300

# STT Provider
STT_PROVIDER=riva
STT_FALLBACK_PROVIDER=deepgram
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_API_KEY
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en
DEEPGRAM_TIMEOUT=300

# LLM Provider
LLM_PROVIDER=deepseek
LLM_FALLBACK_PROVIDER=nvidia
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_LLM_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT=120

# Pyannote (Diarization)
DIARIZATION_USE_PYANNOTE=true
PYANNOTE_HF_TOKEN=YOUR_HUGGINGFACE_TOKEN
PYANNOTE_MODEL_NAME=pyannote/speaker-diarization-3.1
PYANNOTE_DEVICE=

# Silero VAD
VAD_USE_SILERO=true
VAD_THRESHOLD=0.5
VAD_MIN_SPEECH_DURATION_MS=250
VAD_MIN_SILENCE_DURATION_MS=500
VAD_FILTER_BEFORE_STT=true
VAD_MIN_CHUNK_SECONDS=3.0

# Audio Chunking
AUDIO_CHUNK_DURATION_MINUTES=10
AUDIO_CHUNK_OVERLAP_SECONDS=30
MAX_AUDIO_CHUNK_BYTES=26214400

# GCP Cloud Run & Cloud Tasks
GCP_PROJECT=YOUR_GCP_PROJECT_ID
GCP_REGION=us-central1
WORKER_URL=https://samaa-worker-xxxxx-uc.a.run.app
GCP_WORKER_SA_EMAIL=samaa-worker-sa@YOUR_PROJECT.iam.gserviceaccount.com
PIPELINE_VERSION=v1
CLOUD_TASKS_QUEUE=pipeline-queue

# App
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS (update with your domain)
CORS_ORIGINS=https://cxsamaa.store,https://www.cxsamaa.store
